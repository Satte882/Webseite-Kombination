---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="0Admin Geldfluss-Check – DPPFOR" description="Schätzen Sie gebundenes Kapital und den Aufwand für die Nachverfolgung offener Rechnungen.">
  <main class="subpage-shell calculator-page">
    <header class="subpage-topbar">
      <a class="brand" href="/"><img class="brand-logo" src="/images/logo.svg" alt="" /><span><strong>DPPFOR</strong><small>0Admin Geldfluss-Check</small></span></a>
      <nav class="topnav"><a href="/">Start</a><a href="/cockpit/">Cockpit</a></nav>
    </header>
    <section class="subpage-hero"><p class="micro">0Admin Geldfluss-Check</p><h1>Was kosten offene Posten wirklich?</h1><p>Schätzen Sie, wie viel Kapital, Arbeitszeit und Planungssicherheit durch einen klareren Rechnungsprozess gebunden sind.</p></section>
    <section class="calculator-grid" data-calculator>
      <form class="calc-panel">
        <label><span>Rechnungen pro Monat</span><input name="invoices" type="range" min="1" max="500" value="45" /><strong data-value="invoices">45 Rechnungen</strong></label>
        <label><span>Durchschnittlicher Rechnungsbetrag</span><input name="avg" type="range" min="100" max="50000" step="100" value="2500" /><strong data-value="avg">2.500 €</strong></label>
        <label><span>Durchschnittlicher Zahlungsverzug</span><input name="delay" type="range" min="0" max="180" value="28" /><strong data-value="delay">28 Tage</strong></label>
        <label><span>Zeitaufwand pro Woche</span><input name="hours" type="range" min="0" max="40" step="0.5" value="6" /><strong data-value="hours">6 Stunden</strong></label>
        <label><span>Interner Stundensatz</span><input name="rate" type="range" min="20" max="200" value="65" /><strong data-value="rate">65 €/h</strong></label>
      </form>
      <aside class="calc-results">
        <div class="scenario-tabs"><button class="is-active" type="button" data-scenario="conservative">Konservativ</button><button type="button" data-scenario="realistic">Realistisch</button><button type="button" data-scenario="optimistic">Optimistisch</button></div>
        <div class="metric-card"><span>Möglicher Liquiditätseffekt</span><strong data-metric="liquidity">0 €</strong><small>durch kürzere Verzögerung</small></div>
        <div class="metric-row"><div class="metric-card"><span>Gebundenes Kapital</span><strong data-metric="bound">0 €</strong></div><div class="metric-card"><span>Zeitpotenzial/Jahr</span><strong data-metric="hours">0 h</strong></div></div>
        <div class="metric-row"><div class="metric-card"><span>Interner Aufwand/Jahr</span><strong data-metric="cost">0 €</strong></div><div class="metric-card"><span>Zahlungseingang</span><strong data-metric="days">0 → 0</strong></div></div>
        <p data-metric="insight">Ihre Ergebnisse werden berechnet.</p>
        <button class="button" type="button" data-dialog-open="contact">Zahlen für meinen Betrieb besprechen</button>
      </aside>
    </section>
  </main>
  <script is:inline src="/scripts/estimate.js" defer></script>
</BaseLayout>
